# ═══════════════════════════════════════════════════════════════
# Ravian Backend — Environment Variables
# Copy this to .env and fill in your actual values
# ═══════════════════════════════════════════════════════════════

# App
DEBUG=false
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
WORKERS=2

# Security
JWT_SECRET_KEY=your-super-secret-jwt-key-here-change-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database (PostgreSQL)
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ravian_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SSL=false

# CORS — comma-separated origins
CORS_ORIGINS=https://ravian.vercel.app,https://ravian.ai,http://localhost:3000

# OpenAI
OPENAI_API_KEY=sk-...
CHATBOT_API_KEY=sk-...
CHATBOT_MODEL=gpt-4
CHATBOT_ENABLED=true

# Groq API (Whisper STT)
GROQ_API_KEY=gsk_...

# Teaching Assistant
CHROMA_DB_PATH=./chroma_db
WHISPER_MODEL=whisper-large-v3-turbo
TA_EMBEDDING_MODEL=text-embedding-3-small
TA_LLM_MODEL=gpt-4o-mini
TA_TTS_MODEL=tts-1
TA_TTS_VOICE=nova

# Voice / VAPI
VAPI_API_KEY=your-vapi-api-key
VAPI_PHONE_NUMBER_ID=your-vapi-phone-number-id
VAPI_ASSISTANT_ID=your-vapi-assistant-id

# Google Calendar
GOOGLE_CALENDAR_CREDENTIALS_FILE=/path/to/google-calendar-key.json
GOOGLE_CALENDAR_ID=primary

# Twilio (WhatsApp) — optional
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Intent Recognition
INTENT_RECOGNITION_ENABLED=true
USE_PRODUCTION_INTENT_CLASSIFIER=true

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_FAIL_OPEN=true
